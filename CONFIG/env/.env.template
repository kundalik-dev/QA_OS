# .env.template — Environment Variables Template
# Copy this to .env and fill in real values
# NEVER commit .env — only commit this template file
# Real values stored in: password manager (Bitwarden / 1Password)

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
APP_NAME=
APP_URL=http://localhost:3000
NODE_ENV=development            # development | staging | production

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DATABASE_URL=                   # postgresql://user:password@host:5432/dbname
DATABASE_DIRECT_URL=            # for Prisma migrations (direct connection)

# ─────────────────────────────────────────────
# AUTH
# ─────────────────────────────────────────────
NEXTAUTH_SECRET=                # generate: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=

# ─────────────────────────────────────────────
# EMAIL
# ─────────────────────────────────────────────
EMAIL_FROM=
RESEND_API_KEY=                 # https://resend.com
# OR
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─────────────────────────────────────────────
# PAYMENTS
# ─────────────────────────────────────────────
RAZORPAY_KEY_ID=                # https://dashboard.razorpay.com
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# OR
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# STORAGE / FILES
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
# OR
CLOUDINARY_URL=

# ─────────────────────────────────────────────
# AI / APIs
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=              # https://console.anthropic.com
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ─────────────────────────────────────────────
# ANALYTICS & MONITORING
# ─────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=              # Google Analytics
SENTRY_DSN=
POSTHOG_KEY=

# ─────────────────────────────────────────────
# SOCIAL AUTH (OAuth)
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─────────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_BETA=false
NEXT_PUBLIC_MAINTENANCE_MODE=false
